# Supply-chain cooldown: never adopt a freshly published version. npm only
# considers a release once it is at least this many DAYS old, so a malicious
# version that is published and then yanked within a couple of days never makes
# it into our tree. Mitigates the npm supply-chain attacks where bad versions
# are caught and removed within hours.
#
# Native npm setting; enforced by npm >= 11.10.0 (older npm ignores it safely).
# `npm ci` is unaffected because it installs exact lockfile versions; this only
# gates resolving NEW versions (npm install <pkg>, npm update).
min-release-age=3
